PORT=3000

# 正式上线必须改成网站正式域名，例如：
# ALLOWED_ORIGIN=https://jobs.example.com
# 如果有多个正式域名，用英文逗号隔开。
ALLOWED_ORIGIN=*

# 如果部署在 Render、Railway、公司反向代理、Nginx 后面，可改为 true。
TRUST_PROXY=false

# 发件邮箱 SMTP 配置。QQ 邮箱请填写 SMTP 授权码，不要填写登录密码。
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-sender@qq.com
SMTP_PASS=your-smtp-auth-code

# 招聘申请接收邮箱。
MAIL_TO=380704292@qq.com

# 简历大小和防频繁提交设置。
RESUME_MAX_SIZE_MB=12
RATE_WINDOW_MS=900000
RATE_MAX=20
